# Optional variables for expert tooling (e.g. `app/tools/research_vetter.py` Mailjet
# sends, or `app/tools/database_manager.py` if you wire a separate Postgres for experts).
# Copy values you need into `backend/.env` — do not commit real secrets.

# --- Optional Postgres (expert tools / local experiments only; main app uses Aurora or SQLite) ---
DB_HOST=localhost
DB_NAME=livepaper
DB_USER=postgres
DB_PASSWORD=

# --- LLM (research vetting path) ---
OPENAI_API_KEY=<your-openai-api-key>

# --- Mailjet (research vetting email; same env names as `research_vetter.py`) ---
MAILJET_API_KEY=<your-mailjet-api-key>
MAILJET_API_SECRET=<your-mailjet-api-secret>
MAILJET_SENDER=your-verified-sender@example.com
