# ── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_REGION=us-west-2

# ── LangFuse observability ───────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# ── Storage ──────────────────────────────────────────────────────────────────
AURORA_CLUSTER_ARN=arn:aws:rds:us-east-1:...
AURORA_SECRET_ARN=arn:aws:secretsmanager:us-east-1:...
AURORA_DATABASE=livepaper

VECTOR_BUCKET=livepaper-vectors-...
SAGEMAKER_ENDPOINT=livepaper-embedding-endpoint

# ── Queue ────────────────────────────────────────────────────────────────────
SQS_INGESTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/.../livepaper-ingest
SQS_ESCALATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/.../livepaper-escalate

# ── Graph ────────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://...auradb.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=...

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=http://localhost:3000
GAP_CONFIDENCE_THRESHOLD=0.55
