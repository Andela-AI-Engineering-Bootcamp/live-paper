# Trash-Bin / VS Code soft-delete artifacts (don't commit these)
*.trh
*.trash
**/trash/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.mypy_cache/
.ruff_cache/
dist/
# uv
uv.lock
# Environment — never commit real secrets
.env
.env.local
.env.production
backend/.env
# Next.js
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.env.local
frontend/tsconfig.tsbuildinfo
# OS
.DS_Store
Thumbs.db
# IDE
.cursor/
.vscode/
.idea/
.claude/

# Terraform working directory (providers, plan cache, local state)
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfplan
# Terraform variable files often contain real secrets (Neo4j password, etc.)
infra/*.tfvars
infra/*.tfvars.json
!infra/*.tfvars.example

# Logs
*.log
# Test artifacts
.pytest_cache/
htmlcov/
.coverage